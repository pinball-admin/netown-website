// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  region                String    @default("GLOBAL")
  role                  String    @default("user")  // 'user' | 'master' | 'admin'
  candyBalance          Int       @default(100)
  totalPredictions      Int       @default(0)
  correctPredictions    Int       @default(0)
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastLoginDate         String?   // YYYY-MM-DD format for streak calculation
  lastLoginAt           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  isVerified            Boolean   @default(false)
  predictionUnlockUntil DateTime?
  posts                 Post[]
  comments              Comment[]
  predictions           UserPrediction[]
  candyTransactions     CandyTransaction[]
  reactions             PostReaction[]
  achievements          UserAchievement[]
  pushSubscriptions     PushSubscription[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model CandyTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String   // 'SIGNUP', 'DAILY_LOGIN', 'COMMUNITY_POST', 'PREDICTION_CORRECT', 'PREDICTION_BONUS', 'CONVERSION', 'ADMIN_ADJUSTMENT'
  description String?
  referenceId String?  // Optional link to related entity (e.g., predictionId, postId)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         String    @id @default(cuid())
  userId     String
  content    String
  imageUrl   String?
  masterKey  String?   @unique
  likes      Int       @default(0)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments   Comment[]
  reactions  PostReaction[]
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  parentId  String?   // For nested replies
  depth     Int       @default(0)  // 0=top-level, 1=nested reply (max 2 levels)
  createdAt DateTime  @default(now())

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // 'like' | 'fire' | 'laugh' | 'sad'
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  type       String   // 'streak_3' | 'streak_7' | 'accuracy_80' | 'predictions_100' | 'champion'
  earnedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPrediction {
  id              String   @id @default(cuid())
  userId          String
  matchId         String
  predictionType  String   // 'MATCH_RESULT' | 'SCORE' | 'OVER_UNDER' | 'TOTAL_GOALS'
  prediction      String   // The actual prediction value (e.g., 'home_win', '2-1', 'over_2.5', '3')
  difficulty      String   @default("easy")  // 'easy' | 'medium' | 'hard'
  isCorrect       Boolean?
  pointsAwarded   Int      @default(0)
  settledAt       DateTime?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, matchId])
  @@index([matchId])
}