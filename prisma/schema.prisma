// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  passwordHash          String?
  displayName           String?
  bio                   String?
  avatarUrl             String?
  preferredLanguage     String    @default("en")
  region                String    @default("GLOBAL")
  role                  String    @default("user")  // 'user' | 'master' | 'admin'
  candyBalance          Int       @default(100)
  totalPredictions      Int       @default(0)
  correctPredictions    Int       @default(0)
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastLoginDate         String?   // YYYY-MM-DD format for streak calculation
  lastLoginAt           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  isVerified            Boolean   @default(false)
  predictionUnlockUntil DateTime?
  referralCode          String?   @unique
  referredById          String?
  referredBy            User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals             User[]    @relation("Referrals")
  posts                 Post[]
  comments              Comment[]
  predictions           UserPrediction[]
  candyTransactions     CandyTransaction[]
  reactions             PostReaction[]
  achievements          UserAchievement[]
  pushSubscriptions     PushSubscription[]
  quizAttempts          DailyQuizAttempt[]
  followers             Follow[]     @relation("following")
  following             Follow[]     @relation("follower")
  bracketEntries        BracketEntry[]
  territoryMembers      TerritoryMember[]
  claimedTerritory      Territory[]
  ownedSections         TerritorySection[]    @relation("SectionOwner")
  approvedSections      TerritorySection[]    @relation("SectionApprover")
  sectionMemberships    TerritorySectionMember[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model CandyTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  type        String   // 'SIGNUP', 'DAILY_LOGIN', 'COMMUNITY_POST', 'PREDICTION_CORRECT', 'PREDICTION_BONUS', 'CONVERSION', 'ADMIN_ADJUSTMENT'
  description String?
  referenceId String?  // Optional link to related entity (e.g., predictionId, postId)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id         String    @id @default(cuid())
  userId     String
  content    String
  imageUrl   String?
  sourceLanguage String @default("en")
  translations  String  @default("{}")
  masterKey  String?   @unique
  sectionId  String?
  likes      Int       @default(0)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  section    TerritorySection? @relation(fields: [sectionId], references: [id])
  comments   Comment[]
  reactions  PostReaction[]

  @@index([sectionId])
}

model Comment {
  id        String    @id @default(cuid())
  postId    String
  userId    String
  content   String
  parentId  String?   // For nested replies
  depth     Int       @default(0)  // 0=top-level, 1=nested reply (max 2 levels)
  createdAt DateTime  @default(now())

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // 'like' | 'fire' | 'laugh' | 'sad'
  createdAt DateTime @default(now())

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  type       String   // 'streak_3' | 'streak_7' | 'accuracy_80' | 'predictions_100' | 'champion'
  earnedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPrediction {
  id              String   @id @default(cuid())
  userId          String
  matchId         String
  predictionType  String   // 'MATCH_RESULT' | 'SCORE' | 'OVER_UNDER' | 'TOTAL_GOALS'
  prediction      String   // The actual prediction value (e.g., 'home_win', '2-1', 'over_2.5', '3')
  reasoning       String?  // Optional user analysis/justification
  difficulty      String   @default("easy")  // 'easy' | 'medium' | 'hard'
  isCorrect       Boolean?
  pointsAwarded   Int      @default(0)
  settledAt       DateTime?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, matchId])
  @@index([matchId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String                    // The user who follows
  followingId String                    // The user being followed
  createdAt   DateTime @default(now())

  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model BracketEntry {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalScore      Int      @default(0)
  candyCost       Int      @default(100)
  isSubmitted     Boolean  @default(false)
  submittedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks           BracketPick[]
}

model BracketPick {
  id              String   @id @default(cuid())
  bracketId       String
  matchSlot       String                  // e.g., "r16-1", "qf-1", "sf-1", "final"
  round           String                  // "round_of_16", "quarter_final", "semi_final", "final"
  pickedTeamId    String                  // Team ID (e.g., "ARG", "BRA")
  pickedTeamName  String                  // Team name for display
  isCorrect       Boolean?
  pointsEarned    Int      @default(0)
  settledAt       DateTime?
  createdAt       DateTime @default(now())

  bracket         BracketEntry @relation(fields: [bracketId], references: [id], onDelete: Cascade)

  @@unique([bracketId, matchSlot])
}

model DailyQuiz {
  id             String   @id @default(cuid())
  date           String   @unique  // YYYY-MM-DD
  question       String
  options        Json              // string[4] - 4 answer options
  correctOption  Int               // 0-3 index of correct answer
  explanation    String
  funFact        String?
  year           Int               // Related World Cup year
  createdAt      DateTime @default(now())

  attempts       DailyQuizAttempt[]
}

model DailyQuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  quizId         String
  selectedOption Int
  isCorrect      Boolean
  answeredAt     DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz           DailyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
}

model Territory {
  id          String             @id @default(cuid())
  teamCode    String             @unique  // 3-letter code like "ARG", "BRA"
  claimedById String?
  claimedAt   DateTime?
  createdAt   DateTime           @default(now())

  claimedBy   User?              @relation(fields: [claimedById], references: [id], onDelete: SetNull)
  members     TerritoryMember[]
}

model TerritoryMember {
  id          String   @id @default(cuid())
  territoryId String
  userId      String
  joinedAt    DateTime @default(now())

  territory   Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([territoryId, userId])
  @@index([userId])
}

model TerritorySection {
  id           String   @id @default(cuid())
  name         String
  description  String?
  slug         String   @unique
  icon         String?
  category     String?
  rules        String?
  status       String   @default("pending") // pending | approved | rejected | banned

  ownerId      String
  owner        User     @relation("SectionOwner", fields: [ownerId], references: [id])

  approvedById String?
  approvedAt   DateTime?
  rejectReason String?
  approvedBy   User?    @relation("SectionApprover", fields: [approvedById], references: [id])

  creationCost Int      @default(100)

  memberCount  Int      @default(0)
  postCount    Int      @default(0)

  createdAt    DateTime @default(now())

  members      TerritorySectionMember[]
  posts        Post[]

  @@index([status])
  @@index([category])
  @@index([slug])
}

model TerritorySectionMember {
  id        String   @id @default(cuid())
  sectionId String
  userId    String
  role      String   @default("member") // member | moderator
  joinedAt  DateTime @default(now())

  section   TerritorySection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sectionId, userId])
  @@index([userId])
}

model LiveMatch {
  id         String   @id
  homeTeam   String
  awayTeam   String
  homeScore  Int      @default(0)
  awayScore  Int      @default(0)
  status     String   @default("scheduled") // 'scheduled' | 'live' | 'ht' | 'finished'
  minute     String?  // e.g., "45+2", "HT", "FT"
  round      String   @default("Group Stage")
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([homeTeam, awayTeam])
}